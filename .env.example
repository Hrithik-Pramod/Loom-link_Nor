# ═══════════════════════════════════════════════════════════════════════════════
# LOOM LINK — Environment Configuration
# Copy to .env and customize for your deployment
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=industrial_grade_security
POSTGRES_DB=loom_link

# Ollama LLM endpoint (host machine)
OLLAMA_URL=http://host.docker.internal:11434
LLM_MODEL=mistral:7b

# Demo mode (set to true for Stavanger demo)
DEMO_MODE=false
